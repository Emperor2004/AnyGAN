# location: /.env.example

# AnyGAN environment config

# Hugging Face token. Leave empty for public models that do not require auth.
# Create tokens at https://huggingface.co/settings/tokens
HF_TOKEN=

# App settings
APP_NAME=AnyGAN
DEBUG=False
LOG_LEVEL=INFO

# Model settings
DEFAULT_DIFFUSION_MODEL=stabilityai/stable-diffusion-xl-base-1.0
ALLOW_EXTERNAL_MODELS=True
DIFFUSION_STEPS=40

# Performance settings
# Options: auto, cpu, cuda
DEVICE=auto

# Experiment settings
SAVE_OUTPUTS=True
OUTPUT_DIR=experiments/
