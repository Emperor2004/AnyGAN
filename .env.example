# =========================
# AnyGAN Environment Config
# =========================

# 🔐 Hugging Face Token
# Get from: https://huggingface.co/settings/tokens
# Leave empty if using only public models
HF_TOKEN=

# =========================
# App Settings
# =========================
APP_NAME=AnyGAN
DEBUG=False

# =========================
# Model Settings
# =========================
# Default model loaded on startup
DEFAULT_MODEL=dcgan

# Maximum allowed model size (in MB)
MAX_MODEL_SIZE_MB=2048

# Allow loading external models via Hugging Face links
ALLOW_EXTERNAL_MODELS=True

# =========================
# Performance Settings
# =========================
# Options: auto / cpu / cuda
DEVICE=auto

# Enable caching for faster reloads
ENABLE_CACHE=True

# =========================
# UI Settings
# =========================
THEME=playful
SHOW_FUN_FACTS=True

# =========================
# Experiment Settings
# =========================
# Save generated outputs locally
SAVE_OUTPUTS=True

# Directory to store outputs
OUTPUT_DIR=experiments/